{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": ["SSH_AUTH_SOCK"],
  "tasks": {
    "includecheck": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:no-typecheck": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "verify-migrations-order": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["typecheck"],
      "outputs": []
    }
  }
}
